// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  firstname        String
  lastname         String
  organization     String?
  role             UserRole? // 👈 Uses enum now!
  isVerified       Boolean   @default(false)
  // Admin deactivation switch — enforced in JwtStrategy so revoking access
  // takes effect immediately rather than waiting for the token to expire
  // (same reasoning as RolesGuard's role check).
  isActive         Boolean   @default(true)
  agreedToTerms    Boolean   @default(false)
  subscribedToNews Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  otps                 Otp[]
  refreshTokens        RefreshToken[]
  verificationSessions VerificationSession[]
  mentorChats          MentorChat[]
  businessPlans        BusinessPlan[]
  comments             Comment[]

  brandAssets          BrandAsset[]
  chatSessions         ChatSession[]

  mentorConnections MentorConnection[]
  // Present only when this user has been promoted to MENTOR by an admin —
  // links their login to the (previously login-less) Mentor directory row.
  mentorProfile     Mentor?
  menteeMessages    MenteeMessage[]
  courseProgress    CourseProgress[]
  eventAttendance   EventAttendance[]
  userBadges        UserBadge[]
  activityLogs      ActivityLog[]
  tributes          Tribute[]
  nominations       Nomination[]
  moduleProgress    ModuleProgress[]
  greenActions      GreenAction[]
  greenProjectSupport GreenProjectSupport[]
  spotlightLikes      SpotlightLike[]
  creditTransactions  CreditTransaction[]
  notifications       Notification[]

  @@map("users")
}

enum UserRole {
  STUDENT
  PROFESSIONAL
  ENGINEER
  MENTOR
  ADMIN
  OTHER
}

model Otp {
  id        String   @id @default(uuid())
  code      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  useCase   UseCase

  createdAt DateTime @default(now())

  @@map("otps")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)

  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model VerificationSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime

  @@map("verification_sessions")
}

enum UseCase {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model NewsletterSubscription {
  id        String  @id @default(uuid())
  firstName String
  email     String  @unique
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())

  @@map("newsletter_subscriptions")
}

model PartnerRequest {
  id               String  @id @default(uuid())
  fullName         String
  organizationName String
  email            String
  message          String
  wantsSponsorship Boolean @default(false)

  status PartnerRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("partner_requests")
}

enum PartnerRequestStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

model ContactMessage {
  id               String  @id @default(uuid())
  fullName         String
  email            String
  subject          String
  message          String
  wantsPartnership Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_messages")
}

model MentorChat {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages MentorMessage[]

  @@map("mentor_chats")
}

model MentorMessage {
  id     String     @id @default(uuid())
  chatId String
  chat   MentorChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  role    MentorMessageRole
  content String

  createdAt DateTime @default(now())

  @@map("mentor_messages")
}

enum MentorMessageRole {
  USER
  ASSISTANT
}

model BusinessPlan {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessIdea    String
  industry        String
  targetAudience  String
  skills          String
  budget          String
  location        String
  experienceLevel String
  goal            String

  aiResponse Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("business_plans")
}

enum BrandAssetType {
  LOGO
  BUSINESS_CARD
  LETTERHEAD
  EMAIL_SIGNATURE
  INVOICE
  QUOTATION
  COMPANY_PROFILE
  CAPABILITY_STATEMENT
  BRAND_GUIDELINES
}

enum BrandAssetStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model BrandAsset {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  externalAssetId String? @unique
  jobId           String?

  assetType BrandAssetType
  status    BrandAssetStatus @default(PENDING)

  version       Int     @default(1)
  parentAssetId String?

  inputsSnapshot Json
  aiContent      Json?
  rawResponse    Json?

  pdfUrl            String?
  docxUrl           String?
  pngUrl            String?
  svgLightUrl       String?
  svgDarkUrl        String?
  pngTransparentUrl String?

  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([assetType])
  @@index([status])
  @@map("brand_assets")
}


model ChatSession {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  visitorType ChatVisitorType @default(UNKNOWN)
  status      ChatSessionStatus @default(OPEN)

  title String?

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([visitorType])
  @@index([status])
  @@map("chat_sessions")
}

model ChatMessage {
  id String @id @default(uuid())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  sender  ChatSender
  content String

  aiStatus   String?
  aiRawReply Json?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}

enum ChatVisitorType {
  STUDENT
  MENTOR
  PARTNER
  UNKNOWN
}

enum ChatSessionStatus {
  OPEN
  CLOSED
  ESCALATED
}

enum ChatSender {
  USER
  BOT
}
// ---------------------------------------------------------------------------
// Engagement models — mentors, opportunities, courses, events, badges,
// activity feed, community spotlight. Added to back the Student Dashboard,
// which previously rendered hardcoded numbers with no backing data.
// ---------------------------------------------------------------------------

model Mentor {
  id        String  @id @default(uuid())
  name      String
  role      String
  company   String?
  avatarUrl String?
  bio       String?
  skills    String[]
  isActive  Boolean @default(true)

  // Nullable: older/seed directory rows may still have no linked login.
  // When set, this Mentor IS a real User (role: MENTOR) who can log in
  // and see their own "My Mentees" dashboard.
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  connections MentorConnection[]

  @@index([isActive])
  @@map("mentors")
}

enum MentorConnectionStatus {
  PENDING
  ACTIVE
  COMPLETED
  DECLINED
}

model MentorConnection {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentorId String
  mentor   Mentor @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  status            MentorConnectionStatus @default(PENDING)
  sessionsCompleted Int                    @default(0)
  nextSessionAt     DateTime?

  messages MenteeMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, mentorId])
  @@index([userId])
  @@map("mentor_connections")
}

/** Direct mentor <-> mentee messaging within a connection (distinct from
 *  MentorChat/MentorMessage, which back the AI mentor assistant). */
model MenteeMessage {
  id           String           @id @default(uuid())
  connectionId String
  connection   MentorConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  content String

  createdAt DateTime @default(now())

  @@index([connectionId])
  @@map("mentee_messages")
}

model Opportunity {
  id          String   @id @default(uuid())

  title       String
  description String?

  company     String

  category    String?
  location    String?
  type        String?

  source      String   @default("MANUAL")

  provider    String?
  externalId  String?

  url         String?
  applyUrl    String?

  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)

  postedAt    DateTime @default(now())

  @@unique([provider, externalId], name: "provider_externalId")

  @@index([category])
  @@index([isFeatured])
  @@index([isActive])

  @@map("opportunities")
}

model Course {
  id          String  @id @default(uuid())
  // Stable, human-readable identifier used in frontend URLs
  // (/dashboard/green-impact/:courseSlug). Generated from title on create.
  slug        String  @unique
  title       String
  description String?
  category    String?
  // Free-form sub-tags for sorting/filtering WITHIN a category — e.g.
  // ["Web Development", "Beginner"] on an education course, or
  // ["Energy", "Certification"] on a climate one. Separate from `category`,
  // which only ever holds "education" | "climate" and decides which page
  // (Academy vs Green Impact) the course shows up on at all.
  tags        String[] @default([])
  // Admin-curated spotlight — lets you run 300 courses but only surface a
  // handful on the toolkit landing pages, same mechanism as Event.isFeatured.
  isFeatured  Boolean  @default(false)
  // Extra display fields that used to live hardcoded in
  // sustainabilityCourses.ts (image, duration, contactHours, mode, level,
  // certificateAvailable, learningOutcomes, shortDescription). Kept as JSON
  // instead of a wall of nullable columns since it's display metadata, not
  // relational data — same reasoning as Module.content.
  metadata Json?
  // NOTE: totalModules is now a DENORMALIZED CACHE, kept in sync by the
  // modules service whenever a Module is created/deleted for this course.
  // The source of truth is COUNT(modules). Never set this by hand — it
  // exists so list views don't need a join/count on every request.
  totalModules Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress CourseProgress[]
  modules  Module[]

  @@index([isActive])
  @@map("courses")
}

model Module {
  id       String @id @default(uuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Stable identifier for /dashboard/green-impact/:courseSlug/:lessonSlug.
  // Unique per-course (not globally), generated from title on create.
  slug    String
  title   String
  // Rich content — store structured JSON (sections/paragraphs/media) so the
  // frontend can render it the same way it rendered the old hardcoded
  // sustainabilityCourses.ts data, just sourced from the DB instead.
  content Json
  order   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress ModuleProgress[]

  @@unique([courseId, slug])
  @@index([courseId])
  @@index([courseId, order])
  @@map("modules")
}

model ModuleProgress {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  // Section ids the user has checked "done" — validated against
  // Module.content.sections[].id when toggled, not enforced at the DB
  // level (Postgres text[] can't foreign-key into JSON).
  completedSectionIds String[] @default([])
  isCompleted         Boolean  @default(false)
  completedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, moduleId])
  @@index([userId])
  @@map("module_progress")
}

/** A sustainability action a user logs themselves (recycling, using
 *  transit, energy saving, etc). Everything on the Green Impact dashboard
 *  (CO2 tracked, points, ranking) is computed from real rows in this
 *  table — nothing here is a fabricated number.
 *
 *  Point formula, picked as a reasonable, documented default rather than
 *  guessed silently: 1 point per kg of CO2 offset, rounded to the nearest
 *  whole point. Revisit if you want a different formula later — it's
 *  computed in one place (GreenImpactService.pointsFor) so changing it
 *  doesn't require a migration. */
/** Community-nominated sustainability projects. There is no payment
 *  processor wired in anywhere (checked — nothing in this codebase talks
 *  to Stripe or similar), so "raisedAmountMinor" is NOT a record of real
 *  money moving — it's an admin-editable running total, same honesty
 *  tradeoff as everywhere else that doesn't have real billing yet.
 *  "Supporting" a project (GreenProjectSupport) IS real — it's a genuine
 *  user action, just not a financial transaction. Don't wire a "Pay" button
 *  to this without adding real payment processing first — same warning as
 *  the Hall of Fame nomination flow. */
model GreenProject {
  id          String @id @default(uuid())
  title       String
  description String
  imageUrl    String?

  goalAmountMinor   Int
  raisedAmountMinor Int     @default(0)
  isActive          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supporters GreenProjectSupport[]

  @@map("green_projects")
}

model GreenProjectSupport {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   GreenProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([userId, projectId])
  @@map("green_project_support")
}

// Internal marketplace listings for the Green Exchange — admin-managed,
// same "no hardcoded content" convention as ClimateReport/Course/Event.
// Credits here are a gamified in-platform reward, not a real external
// carbon-credit market — pointsPerCredit is the cost/proceeds in the
// user's Green Exchange balance, not real currency.
model CreditListing {
  id                String   @id @default(uuid())
  title             String
  description       String?
  pointsPerCredit   Float
  availableQuantity Int      @default(0)
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions CreditTransaction[]

  @@map("credit_listings")
}

model CreditTransaction {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listingId String
  listing   CreditListing @relation(fields: [listingId], references: [id])

  type        String // BUY | SELL
  quantity    Int
  // Negative for BUY (balance spent), positive for SELL (balance gained).
  pointsDelta Float

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([listingId])
  @@map("credit_transactions")
}

model ClimateReport {
  id          String  @id @default(uuid())
  title       String
  description String?
  // External link to the full report (PDF, page, etc). Optional so a
  // report can be published as a description-only teaser first and the
  // link added later.
  link        String?
  isActive    Boolean @default(true)
  // Lower sortOrder shows first; ties break by createdAt desc (newest
  // first) — same convention as Course/Event ordering elsewhere.
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("climate_reports")
}

model GreenAction {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String // RECYCLING | TRANSPORT | ENERGY | WASTE_REDUCTION | TREE_PLANTING | OTHER
  description String?
  co2OffsetKg Float
  // Optional Greater Manchester borough the action was logged under (e.g.
  // "City Centre", "Salford", "Trafford"). Free text like Course.category —
  // powers the real "Impact by Area" chart once users start tagging their
  // logs; areas with no logged actions simply don't appear in that chart.
  area        String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("green_actions")
}

model CourseProgress {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  completedModules Int     @default(0)
  isCompleted      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
  @@map("course_progress")
}

model Event {
  id          String    @id @default(uuid())
  title       String
  description String?
  location    String?
  imageUrl    String?
  // 'Virtual' | 'In-Person' | 'Hybrid' — free-form like Course.category
  // rather than an enum, so the admin event form can add new modes without
  // a migration. Frontend badges default to 'In-Person' when unset.
  mode        String?
  // Optional external URL — registration page, Zoom/Meet link, Eventbrite,
  // etc. Purely optional so events with no online component (walk-in
  // workshops) don't need one.
  link        String?
  startsAt    DateTime
  endsAt      DateTime?
  isActive    Boolean   @default(true)
  // Featured events are pinned first in findUpcoming(), ahead of anything
  // sorted purely by date — lets an admin put one event front-and-centre
  // on the dashboard regardless of how soon it is.
  isFeatured  Boolean   @default(false)
  // Admin manually ticks an event off as done — distinct from isActive
  // (soft-delete/hide). A completed event stays visible in the full
  // events archive ("View All Events") but drops out of the upcoming
  // list even if its date logic would otherwise still show it.
  isCompleted Boolean   @default(false)
  // Free-form chips shown on the public Events page cards (e.g. "AI/ML",
  // "Networking") — same convention as Course.tags.
  tags        String[]  @default([])

  createdAt DateTime @default(now())

  attendees EventAttendance[]

  @@index([isActive])
  @@index([startsAt])
  @@map("events")
}

model EventAttendance {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  status String @default("REGISTERED")

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@index([userId])
  @@map("event_attendance")
}

model Badge {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  icon        String?

  createdAt DateTime @default(now())

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId String
  badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model Tribute {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  message String

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("tributes")
}

model Nomination {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  nomineeName String
  category    String?
  story       String

  // PENDING | APPROVED | REJECTED — admin has to approve before a
  // nomination shows up as a "Recent Nomination" anywhere public.
  status     String    @default("PENDING")
  reviewedAt DateTime?

  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("nominations")
}
model ActivityLog {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String
  message String
  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model SpotlightStory {
  id String @id @default(uuid())

  authorId String?
  author   User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  title       String
  description String

  authorName String
  authorRole String

  avatarColor String? @default("bg-red-600")
  imageUrl    String?

  status PostStatus @default(PENDING)

  likes    Int @default(0)
  comments Int @default(0)

  isPublished Boolean @default(false)

  createdAt DateTime @default(now())

  likedBy     SpotlightLike[]
  commentList Comment[]

  @@index([status])
  @@index([isPublished])
  @@map("spotlight_stories")
}


model Comment {
  id String @id @default(uuid())

  storyId String
  story SpotlightStory @relation(fields: [storyId], references: [id], onDelete: Cascade)

  userId String?
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  content String

  createdAt DateTime @default(now())

  @@index([storyId])
  @@map("comments")
}

model SpotlightLike {
  id      String         @id @default(uuid())
  userId  String
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId String
  story   SpotlightStory @relation(fields: [storyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, storyId])
  @@index([storyId])
  @@map("spotlight_likes")
}

/** Backs the bell icon / Notifications page (per-user feed) and the
 *  separate admin feed ("everything on the platform"). One row per event —
 *  USER-audience rows are owned by `userId`; ADMIN-audience rows are shared
 *  (userId left null) so any admin marking one read clears it for all admins,
 *  matching NotificationsService's markReadAdmin/markAllReadAdmin. */


model Notification {
  id String @id @default(uuid())

  audience NotificationAudience

  // Null when audience = ADMIN — the shared admin feed isn't owned by one
  // particular admin account.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  category NotificationCategory
  title    String
  body     String?

  actionLabel String?
  actionUrl   String?
  metadata    Json?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([audience, userId])
  @@index([audience, isRead])
  @@map("notifications")
}

enum NotificationAudience {
  USER
  ADMIN
}

/** Add new values here as more engagement areas start calling
 *  notifyUser()/notifyAdmins() — COMMUNITY and EVENTS are the only ones
 *  actually referenced right now (community.service.ts, events.service.ts),
 *  the rest are here so the next feature that wants notifications doesn't
 *  need a schema change too. */
enum NotificationCategory {
  COMMUNITY
  EVENTS
  MENTORS
  OPPORTUNITIES
  COURSES
  GREEN_IMPACT
  SYSTEM
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
}


